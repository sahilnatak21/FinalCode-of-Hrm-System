  "how_to_test": {
    "step1_import_csv": {
      "description": "Import test_employees.csv through the app UI",
      "path": "localhost:3000 → Import CSV (sidebar) → upload test_employees.csv",
      "note": "OR copy it as employees.csv in Frontend/python/ to use as Python ML fallback"
    },
    "step2_use_ui": {
      "description": "Use the Team Formation UI",
      "path": "localhost:3000 → Team Formation → fill in project details from any project above → Generate"
    },
    "step3_direct_api": {
      "description": "Call the Python ML API directly with curl",
      "curl_example": "curl -X POST http://localhost:5000/api/ml/team-formation -H 'Content-Type: application/json' -d @project1_payload.json",
      "powershell_example": "Invoke-RestMethod -Uri 'http://localhost:5000/api/ml/team-formation' -Method Post -ContentType 'application/json' -Body (Get-Content test_project_criteria.json | ConvertFrom-Json).projects[0].body | ConvertTo-Json -Depth 10"
    },
    "step4_verify_output": {
      "check_kmeans": "Response → kmeans.selectedK, kmeans.silhouetteScore, kmeans.clusterSummary",
      "check_rf": "Response → randomForestEvaluation.accuracyScore, precision, recall, f1Score, confusionMatrix, featureImportance",
      "check_pseudo_labels": "Response → randomForestEvaluation.pseudoLabelUsed == true (when no real labels)",
      "check_skill_gap": "Response → skillGapAnalysis.gaps[] with coverageStatus: Covered/Partially Covered/Missing",
      "check_explanation": "Response → members[].explanation.reasonSelected, attentionContributions",
      "check_leader": "Response → leader.leaderScore, leader.leaderReason",
      "check_excluded": "Response → datasetSource.excludedEmployees — must contain Fatima Al-Hassan and Sam Okafor"
    }
  },

  "expected_exclusions": [
    {"name": "Fatima Al-Hassan", "reason": "On Leave"},
    {"name": "Sam Okafor",       "reason": "Unavailable"}
  ],

